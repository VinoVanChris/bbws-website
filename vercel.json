{
  "buildCommand": "npm run build",
  "outputDirectory": "_site",
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "bbws-website.vercel.app" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "errors": [
    { "statusCode": 404, "destination": "/404.html" }
  ]
}
