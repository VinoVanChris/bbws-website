<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if postTitle %}{{ postTitle }} | Broadway Beer Wine &amp; Spirits{% else %}{{ title }}{% endif %}</title>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-970988484"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-970988484');
  </script>
  {% if robots %}<meta name="robots" content="{{ robots }}" />{% endif %}
  <meta name="description" content="{{ description }}" />

  <!-- ═══ SEO ═══════════════════════════════════════════════════════ -->
  <link rel="canonical" href="{{ canonical }}" />
  <!-- Open Graph -->
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:url" content="{{ canonical }}" />
  <meta property="og:site_name" content="Broadway Beer Wine &amp; Spirits" />
  <meta property="og:locale" content="en_CA" />
  <meta property="og:title" content="{{ ogTitle or title }}" />
  <meta property="og:description" content="{{ ogDescription or description }}" />
  <meta property="og:image" content="{{ ogImage }}" />
  {% if ogImageWidth %}<meta property="og:image:width" content="{{ ogImageWidth }}" />{% endif %}
  {% if ogImageHeight %}<meta property="og:image:height" content="{{ ogImageHeight }}" />{% endif %}
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ ogTitle or title }}" />
  <meta name="twitter:description" content="{{ ogDescription or description }}" />
  <meta name="twitter:image" content="{{ ogImage }}" />
  <!-- Geo -->
  <meta name="geo.region" content="CA-BC" />
  <meta name="geo.placename" content="Vancouver, BC" />
  <meta name="geo.position" content="49.2639277;-123.1673546" />
  <meta name="ICBM" content="49.2639277, -123.1673546" />
  {% if publishedTime %}
  <meta property="article:published_time" content="{{ publishedTime }}" />
  <meta property="article:author" content="Broadway Beer Wine &amp; Spirits" />
  {% endif %}
  {% if postTitle and ogType == 'article' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ postTitle | dump | safe }},
    "description": {{ description | dump | safe }},
    "datePublished": "{{ publishedTime | truncate(10, true, '') }}",
    "url": {{ canonical | dump | safe }},
    "image": {{ ogImage | dump | safe }},
    "author": {
      "@type": "Organization",
      "name": "Broadway Beer Wine & Spirits",
      "url": "https://www.broadwaybeerwine.ca"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Broadway Beer Wine & Spirits",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.broadwaybeerwine.ca/images/logo.jpg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ canonical | dump | safe }}
    }
  }
  </script>
  {% elif schema %}
  <script type="application/ld+json">
  {{ schema | safe }}
  </script>
  {% endif %}
  <!-- ════════════════════════════════════════════════════════════ -->
  <link rel="stylesheet" href="/css/style.css?v=17" />
  <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="preload" href="/fonts/rousseau-deco.woff2" as="font" type="font/woff2" crossorigin />
  {% if preloadHero %}
  <link rel="preload" href="{{ preloadHero }}" as="image" type="{{ preloadHeroType or 'image/webp' }}" />
  {% endif %}
</head>
<body>

  <a class="skip-link" href="#main">Skip to content</a>

  <!-- ===== NAV ===== -->
  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/index.html" class="nav-logo" aria-label="Broadway Beer Wine &amp; Spirits home">
        <img src="/images/logo.webp" alt="Broadway Beer Wine &amp; Spirits" />
      </a>
      <ul class="nav-links" role="list">
        <li><a href="/index.html"{% if navPage == 'home' %} class="active"{% endif %}>Home</a></li>
        <li><a href="/about.html"{% if navPage == 'about' %} class="active"{% endif %}>About</a></li>
        <li class="nav-dropdown">
          <button type="button" class="nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true" aria-controls="nav-order-menu">Order Online <svg class="nav-dropdown-chevron" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="10" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg></button>
          <ul id="nav-order-menu" class="nav-dropdown-menu" role="list">
            <li><a href="/delivery.html"{% if navPage == 'delivery' %} class="active"{% endif %}>Delivery Info</a></li>
            <li><a href="https://www.ubereats.com/ca/store/broadway-beer-wine-%26-spirits-2752-west-broadway/txYsHr2XVKO1dt6xFUk8pQ" target="_blank" rel="noopener">Uber Eats</a></li>
            <li><a href="https://www.doordash.com/en-CA/convenience/store/broadway-beer-wine-&-spirits-vancouver-39133145/" target="_blank" rel="noopener">DoorDash</a></li>
          </ul>
        </li>
        <li><a href="/blog.html"{% if navPage == 'blog' %} class="active"{% endif %}>Blog</a></li>
        <li class="nav-dropdown">
          <button type="button" class="nav-dropdown-trigger{% if navPage == 'pairings' or navPage == 'guide' or navPage == 'party' or navPage == 'bcwine' %} active{% endif %}" aria-expanded="false" aria-haspopup="true" aria-controls="nav-guide-menu">Guides <svg class="nav-dropdown-chevron" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="10" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg></button>
          <ul id="nav-guide-menu" class="nav-dropdown-menu" role="list">
            <li><a href="/pairings.html"{% if navPage == 'pairings' %} class="active"{% endif %}>Restaurants & Take-Out</a></li>
            <li><a href="/blog/vancouver-beaches-alcohol-legal.html"{% if navPage == 'guide' %} class="active"{% endif %}>Beaches</a></li>
            <li><a href="/party.html"{% if navPage == 'party' %} class="active"{% endif %}>Party Planner</a></li>
            <li><a href="/bc-wine-beer-spirits-producers.html"{% if navPage == 'bcwine' %} class="active"{% endif %}>BC Producers</a></li>
          </ul>
        </li>
        <li><a href="/corporate.html"{% if navPage == 'corporate' %} class="active"{% endif %}>Corporate</a></li>
        <li><a href="/contact.html"{% if navPage == 'contact' %} class="active"{% endif %}>Contact</a></li>
      </ul>
      <button class="nav-hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
  <div class="mobile-nav" id="mobile-nav" role="navigation" aria-label="Mobile navigation">
    <a href="/index.html" class="{% if navPage == 'home' %}active{% endif %}">Home</a>
    <a href="/about.html" class="{% if navPage == 'about' %}active{% endif %}">About</a>
    <span class="mobile-nav-shop-label">Order Online</span>
    <a href="/delivery.html" class="mobile-nav-sub{% if navPage == 'delivery' %} active{% endif %}">Delivery Info</a>
    <a href="https://www.ubereats.com/ca/store/broadway-beer-wine-%26-spirits-2752-west-broadway/txYsHr2XVKO1dt6xFUk8pQ" target="_blank" rel="noopener" class="mobile-nav-sub">Uber Eats</a>
    <a href="https://www.doordash.com/en-CA/convenience/store/broadway-beer-wine-&-spirits-vancouver-39133145/" target="_blank" rel="noopener" class="mobile-nav-sub">DoorDash</a>
    <a href="/blog.html" class="{% if navPage == 'blog' %}active{% endif %}">Blog</a>
    <span class="mobile-nav-shop-label">Guides</span>
    <a href="/pairings.html" class="mobile-nav-sub{% if navPage == 'pairings' %} active{% endif %}">Restaurants &amp; Take-Out</a>
    <a href="/blog/vancouver-beaches-alcohol-legal.html" class="mobile-nav-sub{% if navPage == 'guide' %} active{% endif %}">Beaches</a>
    <a href="/party.html" class="mobile-nav-sub{% if navPage == 'party' %} active{% endif %}">Party Planner</a>
    <a href="/bc-wine-beer-spirits-producers.html" class="mobile-nav-sub{% if navPage == 'bcwine' %} active{% endif %}">BC Producers</a>
    <a href="/corporate.html" class="{% if navPage == 'corporate' %}active{% endif %}">Corporate</a>
    <a href="/contact.html" class="{% if navPage == 'contact' %}active{% endif %}">Contact</a>
  </div>

  <div id="main">{{ content | safe }}</div>

  {% if postTitle and ogType == 'article' %}
  <!-- ===== RELATED POSTS (populated by main.js from posts.json) ===== -->
  <section id="blog-related-posts" style="background:var(--bg-alt);padding:48px 0;" hidden>
    <div class="container" style="max-width:var(--max-width)">
      <p class="section-eyebrow" style="margin-bottom:12px;">Keep Reading</p>
      <h3 style="margin-bottom:28px;font-size:1.4rem;">More from the Blog</h3>
      <div id="blog-related-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;"></div>
      <div style="margin-top:28px;">
        <a href="/blog.html" class="btn btn-outline">All Posts</a>
      </div>
    </div>
  </section>
  {% endif %}

  <!-- ===== FOOTER ===== -->
  <footer class="site-footer">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand-name">Broadway Beer Wine &amp; Spirits
          <span>Est. 1986 · Kitsilano</span>
        </div>
        <p>Not every bottle, the right one.</p>
      </div>
      <div class="footer-col">
        <h4>Navigate</h4>
        <ul>
          <li><a href="/index.html">Home</a></li>
          <li><a href="/about.html">About</a></li>
          <li><a href="/delivery.html">Delivery</a></li>
          <li><a href="/blog.html">Blog</a></li>
          <li><a href="/pairings.html">Restaurants &amp; Take-Out</a></li>
          <li><a href="/blog/vancouver-beaches-alcohol-legal.html">Beaches Guide</a></li>
          <li><a href="/party.html">Party Planner</a></li>
          <li><a href="/bc-wine-beer-spirits-producers.html">BC Producers</a></li>
          <li><a href="/corporate.html">Corporate</a></li>
          <li><a href="/contact.html">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Visit Us</h4>
        <address>
          2752 W Broadway<br>
          Vancouver, BC<br>
          V6K 2G4<br><br>
          10am to 11pm, 7 days a week
        </address>
      </div>
      <div class="footer-col">
        <h4>Connect</h4>
        <ul>
          <li><a href="https://www.instagram.com/broadwaybeerwineandspirits" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://www.facebook.com/broadwaybeerwineandspirits" target="_blank" rel="noopener">Facebook</a></li>
          <li><a href="/blog.html">Newsletter</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom container" style="max-width:var(--max-width)">
      <p>&copy; 2026 Broadway Beer Wine &amp; Spirits. All rights reserved.</p>
      <div class="footer-social" aria-label="Social media">
        <a href="https://www.instagram.com/broadwaybeerwineandspirits" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://www.facebook.com/broadwaybeerwineandspirits" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
  <script src="/js/sommelier.js"></script>

</body>
</html>
